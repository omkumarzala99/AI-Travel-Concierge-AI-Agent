# ---------------------------------------------------------
# API Keys for LLM Providers (at least one is required)
# ---------------------------------------------------------
# Google Gemini API (Recommended for this project)
GOOGLE_API_KEY=your_gemini_api_key_here

# Groq API (For extremely fast inference)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API (Fallback option)
OPENAI_API_KEY=your_openai_api_key_here

# ---------------------------------------------------------
# Application Configuration Defaults
# ---------------------------------------------------------
# LLM Provider: "gemini", "groq", or "openai"
LLM_PROVIDER=gemini

# Specific Models
# Gemini: "gemini-1.5-flash", "gemini-1.5-pro"
# Groq: "llama-3.1-70b-versatile", "mixtral-8x7b-32768", "llama3-8b-8192"
# OpenAI: "gpt-4o-mini", "gpt-4o"
LLM_MODEL=gemini-1.5-flash

# Embeddings Configuration
# Provider options: "gemini", "openai", or "local" (uses huggingface sentence-transformers via LangChain CPU embeddings)
EMBEDDING_PROVIDER=local

# ---------------------------------------------------------
# LangSmith Observability & Monitoring (Optional)
# ---------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=ai-travel-concierge-rag
